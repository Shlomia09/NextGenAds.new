# NextGenAds Environment Variables
# Copy this to .env and fill in your values

# ============================================================
# Supabase (NEW project — NOT the same as REVAI)
# ============================================================
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ============================================================
# Meta Ads API
# ============================================================
VITE_META_APP_ID=your_meta_app_id_here

# ============================================================
# App URL (for OAuth redirect)
# ============================================================
VITE_APP_URL=http://localhost:5173

# ============================================================
# SERVER-SIDE ONLY (set these in Supabase Edge Functions secrets)
# Never prefix these with VITE_ - they must stay server-side
# Set via: npx supabase secrets set KEY=value --project-ref YOUR_REF
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-...
# META_APP_SECRET=your_meta_app_secret
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# APP_URL=https://nextgenads.vercel.app
